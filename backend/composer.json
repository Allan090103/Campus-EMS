{
    "name": "campusems/backend",
    "description": "CampusEMS REST API - PHP Slim 4 + JWT + MySQL/PDO",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "firebase/php-jwt": "^6.10"
    },
    "config": {
        "audit": {
            "ignore": ["PKSA-y2cr-5h3j-g3ys"]
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    }
}
